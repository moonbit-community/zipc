// Auto-generated correctness tests for the RFC 1951 inflate implementation.
// Fixtures were produced with python3 zlib/zipfile (raw deflate, -15 window).
// Each RAW fixture is real zlib output; the inflate must reproduce ORIG exactly.

///|
/// Decode a hex string into Bytes.
fn hex_to_bytes(s : String) -> Bytes {
  fn nib(v : Int) -> Int {
    if v >= 0x30 && v <= 0x39 {
      v - 0x30
    } else if v >= 0x61 && v <= 0x66 {
      v - 0x61 + 10
    } else if v >= 0x41 && v <= 0x46 {
      v - 0x41 + 10
    } else {
      0
    }
  }
  let arr : Array[Byte] = []
  let mut i = 0
  while i + 1 < s.length() {
    let hi = nib(s[i].to_int())
    let lo = nib(s[i + 1].to_int())
    arr.push(((hi << 4) | lo).to_byte())
    i = i + 2
  }
  Bytes::from_array(arr)
}

///|
/// Decode a hex string into a binary String (one char per byte), matching the
/// zipc binary-string convention used by `of_binary_string`.
fn hex_to_binary_string(s : String) -> String {
  let bytes = hex_to_bytes(s)
  let sb = StringBuilder::new()
  for i = 0; i < bytes.length(); i = i + 1 {
    sb.write_char(bytes[i].to_int().unsafe_to_char())
  }
  sb.to_string()
}

///|
/// Compare two Bytes for exact equality, failing with detail on mismatch.
fn assert_bytes_eq(actual : Bytes, expected : Bytes, label : String) -> Unit raise {
  if actual.length() != expected.length() {
    fail(
      label +
      ": length mismatch got=" +
      actual.length().to_string() +
      " want=" +
      expected.length().to_string(),
    )
  }
  for i = 0; i < expected.length(); i = i + 1 {
    if actual[i] != expected[i] {
      fail(label + ": byte mismatch at " + i.to_string())
    }
  }
}

///|
test "inflate small (btype=1 fixed, orig=5 bytes)" {
  let raw = hex_to_bytes(
    "cb48cdc9c90700",
  )
  let orig = hex_to_bytes(
    "68656c6c6f",
  )
  let got = @deflate.deflate_decompress_raw_bytes(raw, orig.length())
  assert_bytes_eq(got, orig, "small")
}

///|
test "inflate large (btype=2 dynamic, orig=4500 bytes)" {
  let raw = hex_to_bytes(
    "edca470180301045412b5f016a628092d0d910084d3d88e0f8ce33aef35a735f8faa929d8b825d1af21c37d9e193f68fa7f2b9d5585bc891c96432994c2693c96432994c2693ffc82f",
  )
  let orig = hex_to_bytes(
    "",
  )
  let got = @deflate.deflate_decompress_raw_bytes(raw, orig.length())
  assert_bytes_eq(got, orig, "large")
}

///|
test "inflate repeat (btype=2 dynamic, orig=3000 bytes)" {
  let raw = hex_to_bytes(
    "edc2411100000c02a0ac6aff0eabb1071ce9a2aaaafe7e",
  )
  let orig = hex_to_bytes(
    "",
  )
  let got = @deflate.deflate_decompress_raw_bytes(raw, orig.length())
  assert_bytes_eq(got, orig, "repeat")
}

///|
test "inflate dynamic (btype=2 dynamic, orig=7440 bytes)" {
  let raw = hex_to_bytes(
    "edcddb09c3301005d1566e01c195f82f1528d26216f4b0ad55ff31a486fc4d0133671fb735f93957531975dc9a1e4acde2a53cfab41c16eb562a7efaccde0f59f5d8f4b6f204325fb38da2b0763eb1f7ecc5cbeaa115aae9f3ec65f15b9b5a3a7a52aa7eadb469c7c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6c6fea3fd05",
  )
  let orig = hex_to_bytes(
    "",
  )
  let got = @deflate.deflate_decompress_raw_bytes(raw, orig.length())
  assert_bytes_eq(got, orig, "dynamic")
}

///|
test "inflate stored (btype=0 stored, orig=1280 bytes)" {
  let raw = hex_to_bytes(
    "",
  )
  let orig = hex_to_bytes(
    "",
  )
  let got = @deflate.deflate_decompress_raw_bytes(raw, orig.length())
  assert_bytes_eq(got, orig, "stored")
}

///|
test "inflate real zip capsule (deflate members)" {
  let zip = hex_to_binary_string(
    "",
  )
  let archive = match @zipc.of_binary_string(zip) {
    Ok(a) => a
    Err(e) => fail("zip parse failed: " + e)
  }
  //
  match @zipc.find("a.txt", archive) {
    Some(mbr) =>
      match @zipc.member_kind(mbr) {
        File(f) => {
          let got = @zipc.file_to_bytes(f)
          let want = hex_to_bytes(
            "",
          )
          assert_bytes_eq(got, want, "zip:a.txt")
        }
        _ => fail("a.txt is not a file")
      }
    None => fail("missing member a.txt")
  }
  //
  match @zipc.find("b.bin", archive) {
    Some(mbr) =>
      match @zipc.member_kind(mbr) {
        File(f) => {
          let got = @zipc.file_to_bytes(f)
          let want = hex_to_bytes(
            "",
          )
          assert_bytes_eq(got, want, "zip:b.bin")
        }
        _ => fail("b.bin is not a file")
      }
    None => fail("missing member b.bin")
  }
  //
  match @zipc.find("c.txt", archive) {
    Some(mbr) =>
      match @zipc.member_kind(mbr) {
        File(f) => {
          let got = @zipc.file_to_bytes(f)
          let want = hex_to_bytes(
            "",
          )
          assert_bytes_eq(got, want, "zip:c.txt")
        }
        _ => fail("c.txt is not a file")
      }
    None => fail("missing member c.txt")
  }
}
